<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Chronos" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/background_main</item>
        <item name="android:statusBarColor">@color/background_main</item>
        <item name="android:navigationBarColor">@color/background_main</item>
    </style>

    <style name="Theme.Chronos.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/background_main</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_hourglass</item>
        <item name="postSplashScreenTheme">@style/Theme.Chronos</item>
    </style>
</resources>
