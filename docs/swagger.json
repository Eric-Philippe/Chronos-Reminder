{
    "swagger": "2.0",
    "info": {
        "contact": {}
    },
    "paths": {
        "/api/contact": {
            "post": {
                "description": "Submit a contact form with name, email, type, subject, and message",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Contact"
                ],
                "summary": "Submit a contact form",
                "parameters": [
                    {
                        "description": "Contact request",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/api.ContactRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Message sent successfully",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "400": {
                        "description": "Bad request",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "500": {
                        "description": "Internal server error",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/api/dfm": {
            "get": {
                "description": "Get the current user's Don't Forget Me note with all items",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "DFM"
                ],
                "summary": "Get DFM note",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/api.DFMNoteResponse"
                        }
                    }
                }
            }
        },
        "/api/dfm/items": {
            "post": {
                "description": "Add a new item to the user's Don't Forget Me note",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "DFM"
                ],
                "summary": "Add DFM item",
                "parameters": [
                    {
                        "description": "Item content",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/api.DFMAddItemRequest"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Created",
                        "schema": {
                            "$ref": "#/definitions/models.DFMItem"
                        }
                    }
                }
            }
        },
        "/api/dfm/items/{id}": {
            "put": {
                "description": "Update an item's content or checked state",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "DFM"
                ],
                "summary": "Update DFM item",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Item ID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    },
                    {
                        "description": "Update data",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/api.DFMUpdateItemRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/models.DFMItem"
                        }
                    }
                }
            },
            "delete": {
                "description": "Remove an item from the user's Don't Forget Me note",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "DFM"
                ],
                "summary": "Delete DFM item",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Item ID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/api/dfm/reminder": {
            "put": {
                "description": "Configure a recurring reminder for the Don't Forget Me note",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "DFM"
                ],
                "summary": "Set DFM reminder",
                "parameters": [
                    {
                        "description": "Reminder settings",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/api.DFMSetReminderRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/api.DFMNoteResponse"
                        }
                    }
                }
            },
            "delete": {
                "description": "Remove the recurring reminder from the Don't Forget Me note",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "DFM"
                ],
                "summary": "Remove DFM reminder",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/api.DFMNoteResponse"
                        }
                    }
                }
            }
        },
        "/api/dfm/send": {
            "post": {
                "description": "Send the Don't Forget Me note immediately to all configured destinations",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "DFM"
                ],
                "summary": "Send DFM note now",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/api/health": {
            "get": {
                "description": "Returns the health status of the API",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Health"
                ],
                "summary": "Health check",
                "responses": {
                    "200": {
                        "description": "Server is healthy",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "api.ContactRequest": {
            "type": "object",
            "properties": {
                "email": {
                    "type": "string"
                },
                "message": {
                    "type": "string"
                },
                "name": {
                    "type": "string"
                },
                "subject": {
                    "type": "string"
                },
                "type": {
                    "type": "string"
                }
            }
        },
        "api.DFMAddItemRequest": {
            "type": "object",
            "properties": {
                "content": {
                    "type": "string",
                    "example": "Buy groceries"
                }
            }
        },
        "api.DFMNoteResponse": {
            "type": "object",
            "properties": {
                "created_at": {
                    "type": "string"
                },
                "destinations": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "has_reminder": {
                    "type": "boolean"
                },
                "id": {
                    "type": "string"
                },
                "items": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/models.DFMItem"
                    }
                },
                "next_fire_utc": {
                    "type": "string"
                },
                "recurrence_type": {
                    "type": "string"
                },
                "remind_at_utc": {
                    "type": "string"
                },
                "updated_at": {
                    "type": "string"
                }
            }
        },
        "api.DFMSetReminderRequest": {
            "type": "object",
            "properties": {
                "date": {
                    "type": "string",
                    "example": "2026-06-20"
                },
                "destinations": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "example": [
                        "discord_dm",
                        "email"
                    ]
                },
                "recurrence": {
                    "type": "string",
                    "example": "DAILY"
                },
                "time": {
                    "type": "string",
                    "example": "09:00"
                }
            }
        },
        "api.DFMUpdateItemRequest": {
            "type": "object",
            "properties": {
                "checked": {
                    "type": "boolean"
                },
                "content": {
                    "type": "string"
                }
            }
        },
        "models.Account": {
            "type": "object",
            "properties": {
                "created_at": {
                    "type": "string"
                },
                "email_verified": {
                    "type": "boolean"
                },
                "id": {
                    "type": "string"
                },
                "identities": {
                    "type": "array",
