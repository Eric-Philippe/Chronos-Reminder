                "DestinationDiscordDM",
                "DestinationDiscordChannel",
                "DestinationWebhook",
                "DestinationEmail"
            ]
        },
        "models.Identity": {
            "type": "object",
            "properties": {
                "account": {
                    "description": "Relationships",
                    "allOf": [
                        {
                            "$ref": "#/definitions/models.Account"
                        }
                    ]
                },
                "account_id": {
                    "type": "string"
                },
                "avatar": {
                    "description": "optional, snapshot of Discord avatar",
