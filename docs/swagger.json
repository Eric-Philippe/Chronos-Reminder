                "reminders": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/models.Reminder"
                    }
                },
                "timezone": {
                    "description": "Relationships",
                    "allOf": [
                        {
                            "$ref": "#/definitions/models.Timezone"
                        }
                    ]
