                    "type": "string"
                },
                "message": {
                    "type": "string"
                },
                "next_fire_utc": {
                    "type": "string"
                },
                "recurrence": {
                    "type": "integer"
                },
                "remind_at_utc": {
                    "type": "string"
                },
                "snoozed_at_utc": {
                    "type": "string"
                }
            }
