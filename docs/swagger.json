                "created_at": {
                    "type": "string"
                },
                "id": {
                    "type": "string"
                },
                "note": {
                    "description": "Relationships",
                    "allOf": [
                        {
                            "$ref": "#/definitions/models.DFMNote"
                        }
                    ]
                },
                "note_id": {
                    "type": "string"
                },
                "position": {
                    "type": "integer"
                },
                "updated_at": {
                    "type": "string"
                }
            }
        },
        "models.DFMNote": {
            "type": "object",
            "properties": {
                "account": {
                    "description": "Relationships",
                    "allOf": [
                        {
                            "$ref": "#/definitions/models.Account"
                        }
                    ]
                },
                "account_id": {
                    "type": "string"
                },
                "created_at": {
                    "type": "string"
                },
                "id": {
                    "type": "string"
                },
                "items": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/models.DFMItem"
                    }
                },
                "last_sent_at": {
                    "type": "string"
                },
                "next_fire_utc": {
                    "type": "string"
                },
                "recurrence": {
                    "type": "integer"
                },
                "remind_at_utc": {
                    "type": "string"
                },
                "send_discord_dm": {
                    "description": "Private delivery channels; both can be enabled at the same time",
