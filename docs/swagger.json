                },
                "created_at": {
                    "type": "string"
                },
                "external_id": {
                    "description": "e.g., discord_id or app email",
                    "type": "string"
                },
                "id": {
                    "type": "string"
                },
                "provider": {
                    "description": "enum type from database",
                    "allOf": [
                        {
                            "$ref": "#/definitions/models.ProviderType"
                        }
                    ]
                },
                "scopes": {
                    "description": "comma-separated scopes for API keys (e.g., \"reminders.read\")",
                    "type": "string"
                },
                "username": {
                    "description": "snapshot for display purposes",
                    "type": "string"
                }
            }
        },
        "models.JSONB": {
            "type": "object",
            "additionalProperties": true
        },
        "models.ProviderType": {
            "type": "string",
            "enum": [
                "discord",
                "app",
                "api_key"
            ],
            "x-enum-varnames": [
                "ProviderDiscord",
                "ProviderApp",
                "ProviderAPIKey"
            ]
        },
        "models.Reminder": {
            "type": "object",
            "properties": {
                "account": {
                    "description": "Relationships",
                    "allOf": [
                        {
                            "$ref": "#/definitions/models.Account"
                        }
                    ]
                },
                "account_id": {
                    "type": "string"
                },
                "created_at": {
                    "type": "string"
